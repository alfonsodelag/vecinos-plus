---
type Props = {
  eyebrow: string;
  title: string;
  intro?: string;
  align?: "left" | "center";
};

const { eyebrow, title, intro, align = "left" } = Astro.props;
---

<div class:list={["max-w-3xl", align === "center" && "mx-auto text-center"]}>
  <p class="eyebrow">{eyebrow}</p>
  <h2 class="mt-3 font-display text-3xl font-semibold text-ink sm:text-4xl">{title}</h2>
  {intro && <p class="mt-4 text-base leading-7 text-cocoa">{intro}</p>}
</div>
