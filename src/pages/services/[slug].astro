---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Contact from "@/sections/Contact.astro";
import { services, type Service } from "@/content/services";
import { siteConfig, whatsappUrlFor } from "@/config/site";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props as { service: Service };

const related = services.filter((s) => s.slug !== service.slug).slice(0, 3);
const whatsappServiceUrl = whatsappUrlFor(service.title);
---

<BaseLayout
  title={`${service.title} | ${siteConfig.businessName}`}
  description={service.description}
>
  <!-- Breadcrumb -->
  <nav class="border-b border-borderc bg-cream py-3">
    <div class="container-page">
      <ol class="flex items-center gap-2 text-xs text-cocoa">
        <li><a class="hover:text-sage" href="/">Inicio</a></li>
        <li class="text-ink/30">/</li>
        <li><a class="hover:text-sage" href="/services">Servicios</a></li>
        <li class="text-ink/30">/</li>
        <li class="text-ink font-medium">{service.title}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero del servicio -->
  <section class="section-pad bg-white">
    <div class="container-page grid items-center gap-12 lg:grid-cols-2">
      <div>
        <span class="eyebrow">Servicios</span>
        <h1 class="mt-3 font-display text-4xl font-semibold leading-tight text-ink sm:text-5xl">
          {service.title}
        </h1>
        <p class="mt-5 text-lg leading-7 text-cocoa">{service.description}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn-primary" href={whatsappServiceUrl} target="_blank" rel="noopener">
            Escribir por WhatsApp
          </a>
          <a class="btn-secondary" href="#contacto">Solicitar cotización</a>
        </div>
        <p class="mt-5 text-sm font-semibold text-sageDeep">{siteConfig.appointmentNote}</p>
      </div>
      <div class="overflow-hidden rounded-2xl shadow-soft">
        <img
          class="h-80 w-full object-cover lg:h-[420px]"
          src={service.image}
          alt={`${service.title} en ${siteConfig.businessName}`}
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Qué esperar de la consulta -->
  <section class="section-pad bg-cream">
    <div class="container-page grid gap-12 lg:grid-cols-[1.4fr_1fr]">
      <div>
        <span class="eyebrow">Sobre este servicio</span>
        <h2 class="mt-3 font-display text-3xl font-semibold text-ink">
          ¿En qué consiste?
        </h2>
        <p class="mt-6 leading-7 text-cocoa">{service.description}</p>
        <p class="mt-4 leading-7 text-cocoa">
          Cada mudanza se revisa según tu caso para definir el plan más adecuado. Escríbenos para resolver tus dudas y coordinar los detalles.
        </p>
      </div>

      <div class="rounded-2xl bg-white p-8 shadow-soft">
        <h3 class="font-display text-xl font-semibold text-ink">
          ¿Qué esperar del servicio?
        </h3>
        <ul class="mt-5 space-y-3">
          {[
            "Cotización clara antes de coordinar",
            "Revisión de acceso, volumen y detalles logísticos",
            "Coordinación según tu caso y disponibilidad",
          ].map((item) => (
            <li class="flex items-start gap-3">
              <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-sage/10">
                <svg class="h-3 w-3 text-sageDeep" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </span>
              <span class="text-sm leading-6 text-cocoa">{item}</span>
            </li>
          ))}
        </ul>
        <div class="mt-8 border-t border-borderc pt-6">
          <p class="text-sm font-semibold text-ink">¿Tienes dudas sobre este servicio?</p>
          <a
            class="mt-3 inline-flex items-center gap-2 text-sm font-semibold text-sageDeep hover:text-ink"
            href={whatsappServiceUrl}
            target="_blank"
            rel="noopener"
          >
            Escríbenos por WhatsApp
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios relacionados -->
  {related.length > 0 && (
    <section class="section-pad bg-white">
      <div class="container-page">
        <span class="eyebrow">Más servicios</span>
        <h2 class="mt-3 font-display text-2xl font-semibold text-ink">
          Otros servicios que ofrecemos
        </h2>
        <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {related.map((s) => (
            <a
              class="card group overflow-hidden transition hover:-translate-y-1"
              href={`/services/${s.slug}`}
            >
              <img
                class="h-44 w-full object-cover"
                src={s.image}
                alt={s.title}
                loading="lazy"
              />
              <div class="p-5">
                <h3 class="font-display text-lg font-semibold text-ink group-hover:text-sage transition-colors">
                  {s.title}
                </h3>
                <p class="mt-2 text-sm leading-6 text-cocoa line-clamp-2">{s.description}</p>
                <span class="mt-4 inline-flex items-center gap-1 text-xs font-semibold text-sage">
                  Ver servicio
                  <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a class="btn-secondary" href="/services">Ver todos los servicios</a>
        </div>
      </div>
    </section>
  )}

  <Contact />
</BaseLayout>
