---
import SectionTitle from "@/components/SectionTitle.astro";
import { sanityClient, blogPostsQuery, blogPostsParams, type SanityPost } from "@/lib/sanity";
import { getPostImage, formatDate } from "@/lib/portableText";
import { posts as staticPosts } from "@/content/blog";

let posts: SanityPost[] = [];
try {
  posts = await sanityClient.fetch<SanityPost[]>(blogPostsQuery, blogPostsParams);
} catch (_) {}

const showPosts = posts.length > 0 ? posts.slice(0, 3) : null;
---

<section class="section-pad bg-white">
  <div class="container-page">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionTitle
        eyebrow="Blog"
        title="Consejos prácticos para tu próxima mudanza."
      />
      <a class="btn-secondary md:mb-1" href="/blog">Ver todos</a>
    </div>

    {showPosts ? (
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {showPosts.map((post, i) => (
          <article class="card group overflow-hidden transition hover:-translate-y-1">
            <div class="overflow-hidden">
              <img
                class="h-52 w-full object-cover transition duration-300 group-hover:scale-105"
                src={getPostImage(post, i)}
                alt={post.title}
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <time
                class="text-xs font-semibold uppercase tracking-[0.14em] text-sage"
                datetime={post.publishedAt}
              >
                {formatDate(post.publishedAt)}
              </time>
              <h3 class="mt-3 font-display text-xl font-semibold leading-snug text-ink">
                {post.title}
              </h3>
              <p class="mt-3 line-clamp-3 text-sm leading-6 text-cocoa">{post.excerpt}</p>
              <a
                class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-sage hover:text-ink transition-colors"
                href={`/blog/${post.slug}`}
              >
                Leer más
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {staticPosts.map((post) => (
          <article class="card overflow-hidden">
            <img class="h-52 w-full object-cover" src={post.image} alt={post.title} loading="lazy" />
            <div class="p-6">
              <time class="text-xs font-semibold uppercase tracking-[0.14em] text-sage" datetime={post.date}>{post.date}</time>
              <h3 class="mt-3 font-display text-xl font-semibold leading-snug text-ink">{post.title}</h3>
              <p class="mt-3 text-sm leading-6 text-cocoa">{post.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</section>
