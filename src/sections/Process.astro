---
import SectionTitle from "@/components/SectionTitle.astro";

const steps = [
  {
    number: "1",
    title: "Cuéntanos qué necesitas mover",
    description: "Envíanos punto de salida, destino, tipo de artículos y fecha estimada.",
  },
  {
    number: "2",
    title: "Revisamos la mudanza contigo",
    description: "Te orientamos sobre disponibilidad, logística, acceso, volumen y detalles importantes.",
  },
  {
    number: "3",
    title: "Coordinamos y nos movemos",
    description: "Definimos el plan y te ayudamos a hacer la mudanza de forma más clara y llevadera.",
  },
];
---

<section id="proceso" class="section-pad bg-white">
  <div class="container-page">
    <SectionTitle
      eyebrow="Cómo funciona"
      title="Así de simple es cotizar tu mudanza con Vecinos Plus."
      align="center"
    />
    <div class="mt-12 grid gap-6 sm:grid-cols-3">
      {steps.map((step) => (
        <div class="card p-6">
          <span class="grid h-10 w-10 place-items-center rounded-full bg-ink font-display text-lg font-semibold text-white">
            {step.number}
          </span>
          <h3 class="mt-4 font-display text-xl font-semibold text-ink">{step.title}</h3>
          <p class="mt-2 text-sm leading-6 text-cocoa">{step.description}</p>
        </div>
      ))}
    </div>
    <div class="mt-10 text-center">
      <a class="btn-primary" href="/contact">Empezar cotización</a>
    </div>
  </div>
</section>
