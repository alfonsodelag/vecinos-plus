---
import SectionTitle from "@/components/SectionTitle.astro";
import { faqs } from "@/content/faqs";
---

<section id="faq" class="section-pad bg-cream">
  <div class="container-page grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
    <SectionTitle
      eyebrow="Preguntas frecuentes"
      title="Respuestas claras antes de cotizar tu mudanza."
      intro="Resuelve las dudas más comunes sobre cotizaciones, acarreos, mudanzas en apartamentos y el proceso de coordinación."
    />
    <div class="space-y-4">
      {faqs.map((faq) => (
        <details class="rounded-lg border border-borderc bg-white p-5 shadow-sm">
          <summary class="cursor-pointer font-semibold text-ink">{faq.question}</summary>
          <p class="mt-3 text-sm leading-6 text-cocoa">{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
